  missing = "FIML",
  group = "grade",
  group.label = c('grade_2', 'grade_3', 'grade_4'),
  # cluster = "class_ID",
)

fitmeasures(fit_accuratewordstime_partialmediation, 
            c('df', 'chisq', 'pvalue', 'cfi', 'rmsea'))
summary(fit_accuratewordstime_partialmediation)
# plot_lavaan(fit_accuratewordstime_partialmediation, where = 'browser')
parameterEstimates(fit_accuratewordstime_partialmediation) |> 
