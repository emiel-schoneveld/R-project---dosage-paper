# Load data ----
data <- readRDS(
  here::here('output/data_cleaned.rds')
)

# Interesting models ----
# two waves total time
mod_wordstime_fullmediation <- '
# regression
## Predicting reading
wordreading_score_post ~ wordreading_score_pre + c(post_words_2, post_words_3, post_words_4)*practice_cii_words_unique

## Predicting total words
practice_cii_words_unique ~ c(words_time_2, words_time_3, words_time_4)*practice_cii_time

## Covariances
wordreading_score_pre ~~ practice_cii_time + practice_cii_words_unique

# variances
wordreading_score_pre ~~ wordreading_score_pre
wordreading_score_post ~~ wordreading_score_post
practice_cii_words_unique ~~ practice_cii_words_unique
practice_cii_time ~~ practice_cii_time
'

mod_wordstime_partialmediation <- '
wordreading_score_post ~ c(post_time_2, post_time_3, post_time_4)*practice_cii_time
'

mod_wordstime_totaltimeeffect <- '
post_time_total_2 := (post_words_2*words_time_2) + post_time_2
post_time_total_3 := (post_words_3*words_time_3) + post_time_3
post_time_total_4 := (post_words_4*words_time_4) + post_time_4
'

fit_partialmediation <- sem(
  c(
    mod_wordstime_fullmediation,
    mod_wordstime_partialmediation,
    mod_wordstime_totaltimeeffect
    ),
  data = data |> 
    mutate(
      practice_cii_words_unique = practice_cii_words_unique / 1000
    )
  , 
  missing = "FIML",
  group = "grade",
  group.label = c('grade_2', 'grade_3', 'grade_4'),
  cluster = "class_ID",
)

fitmeasures(fit_partialmediation, 
            c('df', 'chisq', 'pvalue', 'cfi', 'rmsea'))
summary(fit_partialmediation, std = T)

