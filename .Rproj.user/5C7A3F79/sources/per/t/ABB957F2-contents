# Descriptive analyses 
# General syntax ----
## Clear environment
rm(list = ls())

## Load packages
library(tidyverse)
library(readxl)
library(here)

# Load data ----
data <- readRDS(
  here::here('output/data.rds')
)

# Descriptive analysis ----
## Summary ----
summary(data)

## Correlation table
data |> 
  dplyr::select(
    where(is.numeric)
  ) |> 
  cor(
    use = "pairwise.complete.obs"
  ) #|> View()

data |> 
  group_by(grade) |> 
  summarise(
    mean(wordreading_score_pre, na.rm = T)
    )
