## Summary of results ----
### Main effect ----
# Unconstrained model: 
# A positive effect of intervention on DMT at mid-, post- and follow-up measurement for group 5
parameterestimates(
  fit_DMT_maineffect_unconstrained,
  standardized = T
) |> 
  filter(
    str_detect(rhs, 'intervention'),
    op == '~',
    # pvalue < .05
  ) |> 
  arrange(
    lhs, group
  ) |> 
  dplyr::select(lhs, group, est, se, pvalue, std.lv)

# significant difference in intervention effect between grades:
anova(
  fit_DMT_maineffect_unconstrained,
  fit_DMT_maineffect_constrainedgrades
)

### Condition effects ----
# Unconstrained model: 
# A positive effect of condition_LED on DMT at mid-, post- and follow-up and of condition_comb on DMT at follow-up for group 5
parameterestimates(
  fit_DMT_conditioneffect_unconstrained,
  standardized = T
) |> 
  filter(
    str_detect(rhs, 'condition'),
    op == '~',
    # pvalue < .001
  ) |> 
  arrange(
    rhs, lhs, group
  ) |> 
  dplyr::select(lhs, rhs, group, est, se, pvalue, std.lv)


# No significant differences between condition_LED and condition_comb effects within groups: 
# significant effect of condition_LED and condition_comb on DMT at mid-, post- and follow-up for group 5.
anova(
  fit_DMT_conditioneffect_unconstrained,
  fit_DMT_conditioneffect_constrainedconditions
)
parameterestimates(
  fit_DMT_conditioneffect_constrainedconditions,
  standardized = T
) |> 
  filter(
    str_detect(rhs, 'condition'),
    op == '~',
    pvalue < .05
  )

# significant differences between condition_LED or condition_comb effects between groups: 
anova(
  fit_DMT_conditioneffect_unconstrained,
  fit_DMT_conditioneffect_constrainedgrades
)

