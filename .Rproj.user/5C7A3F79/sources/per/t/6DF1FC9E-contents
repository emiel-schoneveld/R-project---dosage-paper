mod_DMT_configural_0 <- '
## Common factor structure
# Common factor factor loadings
DMT_pre =~ 1*DMT_score_pre
DMT_mid =~ 1*DMT_score_mid
DMT_post =~ 1*DMT_score_post
DMT_followup =~ 1*DMT_score_followup

# Common factor variances
DMT_pre ~~ DMT_pre
DMT_mid ~~ DMT_mid
DMT_post ~~ DMT_post
DMT_followup ~~ DMT_followup

# Common factor covariances
DMT_pre ~~ DMT_mid
DMT_pre ~~ DMT_post
DMT_pre ~~ DMT_followup
DMT_mid ~~ DMT_post
DMT_mid ~~ DMT_followup
DMT_post ~~ DMT_followup

# Common factor intercepts
DMT_pre ~ 0*1
DMT_mid ~ 0*1
DMT_post ~ 0*1
DMT_followup ~ 0*1

# Indicator residual variances
DMT_score_pre ~~ 0*DMT_score_pre
DMT_score_mid ~~ 0*DMT_score_mid
DMT_score_post ~~ 0*DMT_score_post
DMT_score_followup ~~ 0*DMT_score_followup

# Indicator intercepts
DMT_score_pre ~ 1
DMT_score_mid ~ 1
DMT_score_post ~ 1
DMT_score_followup ~ 1
'

# Fit and inspect model
fit_DMT_configural_0 <- lavaan(mod_DMT_configural_0,
                                   data = data,
