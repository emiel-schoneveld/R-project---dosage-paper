```{r setup, include=FALSE}
library(crosstalk)
library(plotly)

# data should already exist in your environment, e.g. loaded earlier in the report
vars_to_plot <- c("word_exposures", "accuracy_anytry")
```

## Select a grade

Leave unselected to view the entire sample.

```{r filter, echo=FALSE}
shared_df <- SharedData$new(data, group = "histo_group")

filter_select(
  id      = "grade_select",
  label   = "Grade",
  sharedData = shared_df,
  group   = ~grade
)
```

## Histograms

```{r plots, echo=FALSE, message=FALSE, warning=FALSE, fig.height=5}
plots <- lapply(vars_to_plot, function(v) {
  plot_ly(shared_df, x = as.formula(paste0("~", v)),
          type = "histogram",
          marker = list(line = list(color = "white", width = 0.5))) |>
    layout(
      xaxis = list(title = v),
      yaxis = list(title = "Count"),
      annotations = list(
        text = v, xref = "paper", yref = "paper",
        x = 0.5, y = 1.08, showarrow = FALSE,
        font = list(size = 13)
      )
    )
})

subplot(plots, nrows = 1, margin = 0.06, titleX = TRUE, titleY = TRUE) |>
  layout(showlegend = FALSE) |>
  highlight(persistent = FALSE)
```
