library(lavaangui)

# Interesting models ----
# two waves total time
mod_2waves <- '
# regression
## Predicting reading
wordreading_score_post ~ wordreading_score_pre + practice_cii_words_total

## Predicting total words
practice_cii_words_total ~ wordreading_score_pre + practice_cii_time

## Predicting total time
practice_cii_time ~~ wordreading_score_pre

# variances
wordreading_score_pre ~~ wordreading_score_pre
wordreading_score_post ~~ wordreading_score_post
practice_cii_words_total ~~ practice_cii_words_total
practice_cii_time ~~ practice_cii_time
'

mod_2waves_partialmediation <- '
wordreading_score_post ~ practice_cii_time
'

fit_2waves_partialmediation <- sem(
  c(
    mod_2waves,
    mod_2waves_partialmediation),
  data = data |> 
    mutate(
      wordreading_score_post = wordreading_score_post / 100,
      wordreading_score_pre = wordreading_score_pre / 100
    )
  , 
  missing = "FIML",
  group = "grade",
  group.label = c('grade_2', 'grade_3', 'grade_4'),
  cluster = "class_ID",
)


fitmeasures(fit_2waves_partialmediation, 
            c('df', 'chisq', 'pvalue', 'cfi', 'rmsea'))
summary(fit_2waves_partialmediation, std = T)


fit_2waves_fullmediation <- sem(
  mod_2waves,
  data = data |> 
    mutate(
      wordreading_score_post = wordreading_score_post / 100,
      wordreading_score_pre = wordreading_score_pre / 100
    )
  , 
  missing = "FIML",
  group = "grade",
  group.label = c('grade_2', 'grade_3', 'grade_4'),
  cluster = "class_ID",
)


fitmeasures(fit_2waves_fullmediation, 
            c('df', 'chisq', 'pvalue', 'cfi', 'rmsea'))
summary(fit_2waves_fullmediation)
anova(
  fit_2waves_fullmediation,
  fit_2waves_partialmediation
)


