# Plot all results ----
p_interaction <- (p_interaction_pre +
  p_interaction_exposures +
  p_interaction_accuracy +
  p_interaction_accuracyexposures +
  plot_layout(
    axis = "collect",
    guides = "collect",
    nrow = 2
  )) &
