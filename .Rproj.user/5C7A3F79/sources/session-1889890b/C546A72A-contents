## Function to make an estimates table
format_parameter_table <- function(
    model_fit = NA,
    rhs_filter = 'intervention',
    lhs_filter = 'factor',
    grade_offset = -2,
    exclude_outcome = TRUE
) {
  # Format table
  formatted_output <- model_fit |> 
    parameterestimates(
      standardized = T
    ) |>
    as_tibble() |> 
    filter(
      op == '~',
      str_detect(rhs, str_c(rhs_filter, collapse = '|')),
      str_detect(lhs, str_c(lhs_filter, collapse = '|'))
    ) |> 
    mutate(
      Estimate = format_number_for_table(est, 2),
      SE = format_number_for_table(se, 2),
      p = format_number_for_table(pvalue, 3),
      `Standardised Estimate` = format_number_for_table(std.lv, 2),
      Dummy = rhs,
      Measurement = lhs,
      Grade = str_sub(group, start = -1, end = -1) |> as.integer()+grade_offset,
      Grade = as.character(Grade),
      Measurement_sort = case_when(
        str_detect(lhs, 'mid') ~ 'a',
        str_detect(lhs, 'post') ~ 'b',
        str_detect(lhs, 'follow') ~ 'c'
      )
    ) |> 
    arrange(
      desc(Dummy),
      Measurement_sort,
      Grade
    ) |> 
    dplyr::select(
      Dummy, Measurement, Grade, Estimate, SE, p, `Standardised Estimate`
    ) |> 
    mutate(
      Dummy = case_when(
        Dummy == 'intervention' ~ 'Intention-to-treat',
        Dummy == 'condition_led' ~ 'LED condition',
        Dummy == 'condition_comb' ~ 'Combination condition',
        .default = Dummy
      ),
      p = str_sub(p, 2),
      p = case_when(
        p == '.000' ~ '< .001',
        .default = p
      )
    )
  
  # Include outcome variable
  if (exclude_outcome) {
    formatted_output <- formatted_output |> 
      dplyr::select(
        !Measurement
      )
  }
  
  # Return output
  return(formatted_output)
}

