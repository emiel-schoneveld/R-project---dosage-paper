### Combine data
# By Emiel Schoneveld

# General syntax ----
## Clear environment
rm(list = ls())

## Load packages
library(tidyverse)
library(here)

# Load data ----
## Test data
data_wordreading <- readRDS(
  here('output/data_wordreading.rds')
) |> 
  dplyr::select(
    student_ID, wordreading_score_pre, wordreading_score_post
  ) |> 
  rename(
    fluency_DMT_pre = wordreading_score_pre,
    fluency_DMT_post = wordreading_score_post,
  )

## Characteristics data
data_characteristics <- readRDS(
  here('output/data_characteristics.rds')
)

## Practice data
data_practice <- readRDS(
  here('output/data_practice.rds')
)

## factor scores
### discrete
data_discrete <- readRDS(
  here::here('input/data_discrete.rds')
)

### serial
data_serial <- readRDS(
  here::here('input/data_serial.rds')
)

# Combine data_logs_student, data_wordreading and data_characteristics ----
## Combine
data <- data_practice |> 
  left_join(
    data_characteristics
  ) |> 
  left_join(
    data_wordreading
  ) |> 
  left_join(
    data_discrete
  ) |> 
  left_join(
    data_serial
  )

# Write ----
saveRDS(
  data,
  here("output/data.rds")
)
