#### Combine into one specification
mod_splitted_full_v3 <- c(
  mod_splitted_regression_full,
  mod_splitted_covariance_intercept_structure,
  mod_splitted_modification_freq_and_dur_grade4,
  mod_splitted_modification_freq_and_length_grade2,
