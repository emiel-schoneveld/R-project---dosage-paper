library(lavaangui)
library(lavaan)

# Interesting models ----
# two waves total time
mod_wordstime_fullmediation <- '
# regression
## Predicting reading
wordreading_score_post ~ wordreading_score_pre + practice_cii_words_unique

## Predicting total words
practice_cii_words_unique ~ practice_cii_time

## Covariances
wordreading_score_pre ~~ practice_cii_time + practice_cii_words_unique

# variances
wordreading_score_pre ~~ wordreading_score_pre
wordreading_score_post ~~ wordreading_score_post
practice_cii_words_unique ~~ practice_cii_words_unique
practice_cii_time ~~ practice_cii_time
'

mod_wordstime_partialmediation <- '
wordreading_score_post ~ practice_cii_time
'

fit_partialmediation <- sem(
  c(
    mod_wordstime_fullmediation,
    mod_wordstime_partialmediation
    ),
  data = data |> 
    mutate(
      practice_cii_words_unique = practice_cii_words_unique / 1000
    )
  , 
  missing = "FIML",
  group = "grade",
  group.label = c('grade_2', 'grade_3', 'grade_4'),
  cluster = "class_ID",
)

fitmeasures(fit_partialmediation, 
            c('df', 'chisq', 'pvalue', 'cfi', 'rmsea'))
summary(fit_partialmediation, std = T)
# plot_lavaan(fit_partialmediation, where = 'browser')
parameterEstimates(fit_partialmediation) |> 
  filter(
    str_detect(rhs, 'time')
  ) |> 
  arrange(
    lhs, rhs, group
  )

fit_fullmediation <- sem(
  mod_wordstime_fullmediation,
  data = data |> 
    mutate(
      practice_cii_words_unique = practice_cii_words_unique / 1000
    )
  , 
  missing = "FIML",
  group = "grade",
  group.label = c('grade_2', 'grade_3', 'grade_4'),
  cluster = "class_ID",
)

fitmeasures(fit_fullmediation, 
            c('df', 'chisq', 'pvalue', 'cfi', 'rmsea'))
summary(fit_fullmediation)
anova(
  fit_fullmediation,
  fit_partialmediation
)

# Accuracy (continues) ----
mod_wordstimeaccuracy_fullmediation <- '
# regression
## Predicting reading
wordreading_score_post ~ wordreading_score_pre + practice_cii_words_unique + practice_accuracy + wordsXaccuracy

## Predicting words and accuracy
practice_cii_words_unique ~ practice_cii_time
practice_accuracy ~ wordreading_score_pre

## covariance
wordreading_score_pre ~~ practice_cii_words_unique + practice_cii_time

# variances
wordreading_score_pre ~~ wordreading_score_pre
wordreading_score_post ~~ wordreading_score_post
practice_cii_words_unique ~~ practice_cii_words_unique
practice_accuracy ~~ practice_accuracy
practice_cii_time ~~ practice_cii_time
'

mod_wordstimeaccuracy_partialmediation <- '
wordreading_score_post ~ practice_cii_time
'

mod_wordstimeaccuracy_accuracycovs <- '
practice_accuracy ~~ practice_cii_words_unique + practice_cii_time
'

mod_wordstimeaccuracy_productcovs <- '
wordsXaccuracy ~~ wordreading_score_pre + practice_cii_words_unique + practice_accuracy + practice_cii_time
'

fit_wordstimeaccuracy_partialmediation <- sem(
    c(
      mod_wordstimeaccuracy_fullmediation,
      mod_wordstimeaccuracy_partialmediation,
      mod_wordstimeaccuracy_accuracycovs,
      mod_wordstimeaccuracy_productcovs
      ),
  data = data |> 
    mutate(
      practice_cii_words_unique = practice_cii_words_unique / 1000,
      
      practice_cii_words_unique = practice_cii_words_unique - mean(practice_cii_words_unique, na.rm = T),
      practice_accuracy = (practice_accuracy - mean(practice_accuracy, na.rm = T))*100,
      
      wordsXaccuracy = practice_cii_words_unique * practice_accuracy
    )
  , 
  missing = "FIML",
  group = "grade",
  group.label = c('grade_2', 'grade_3', 'grade_4'),
  # cluster = "class_ID",
)

fitmeasures(fit_wordstimeaccuracy_partialmediation, 
            c('df', 'chisq', 'pvalue', 'cfi', 'rmsea'))
summary(fit_wordstimeaccuracy_partialmediation)
# plot_lavaan(fit_wordstimeaccuracy_partialmediation, where = 'browser')
parameterEstimates(fit_wordstimeaccuracy_partialmediation) |> 
  filter(
    str_detect(lhs, 'post')
  ) |> 
  arrange(
    lhs, rhs, group
  )


lm(
  wordreading_score_post ~ 
    wordreading_score_pre + 
    practice_cii_words_unique*practice_accuracy
  ,
  data = data |> 
    filter(
      grade == "grade_2"
    ) |> 
    mutate(
      practice_cii_words_unique = practice_cii_words_unique - mean(practice_cii_words_unique, na.rm = T),
      practice_accuracy = practice_accuracy - mean(practice_accuracy, na.rm = T),
    )
) |> summary()



