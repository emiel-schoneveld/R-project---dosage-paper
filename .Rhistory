practice_cii_time ~ 1
'
### Fit full mediation model ----
fit_full <- sem(
mod_full,
data = data,
missing = "FIML",
# group = "grade",
cluster = "class_ID",
# group.equal = c('regressions')
)
## Partial mediation: words ~ pre ----
### Specify partial mediation model ----
mod_add_partial_words_pre <-'
# Direct regression effects of premeasurement on words
practice_cii_words ~ wordreading_score_pre
'
### Fit partial mediation model ----
fit_partial_1 <- sem(
c(mod_full, mod_add_partial_words_pre),
data = data,
missing = "FIML",
# group = "grade",
cluster = "class_ID",
# group.equal = c('regressions')
)
anova(fit_fullmediation_timesum, fit_partial_1)
### Inspect partial mediation model ----
anova(fit_full, fit_partial_1)
#### Adding direct effect of time on post measurement
mod_add_partial_post_time <-'
# Direct regression effects of time on post
wordreading_score_post ~ practice_cii_time
'
### Testing singular additions of partial mediation ----
#### Partial mediation: words ~ pre ----
fit_partial_1 <- sem(
c(mod_full, mod_add_partial_words_pre),
data = data,
missing = "FIML",
# group = "grade",
cluster = "class_ID",
# group.equal = c('regressions')
)
### Inspect partial mediation model ----
anova(fit_full, fit_partial_1)
### Inspect partial mediation model ----
anova(fit_full, fit_partial_2)
#### Partial mediation: post ~ time ----
fit_partial_2 <- sem(
c(mod_full, mod_add_partial_post_time),
data = data,
missing = "FIML",
# group = "grade",
cluster = "class_ID",
# group.equal = c('regressions')
)
### Inspect partial mediation model ----
anova(fit_full, fit_partial_2)
### Testing singular additions of partial mediation ----
